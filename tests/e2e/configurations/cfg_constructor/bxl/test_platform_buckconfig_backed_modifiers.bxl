load("@prelude//:asserts.bzl", "asserts")
load("@prelude//cfg/modifier:cfg_constructor.bzl", "cfg_constructor_post_constraint_analysis", "cfg_constructor_pre_constraint_analysis")
load("@prelude//cfg/modifier:types.bzl", "BuckconfigBackedModifierInfo")
load(":util.bxl", "ALIASES", "get_test_refs")

def _impl(ctx: bxl.Context):
    test_refs = get_test_refs(ctx)

    # Analyze the buckconfig_backed_modifiers target that uses the platforms field.
    # With --config test.use_platform=linux_x86_64, the entry matches and injects
    # the test_linux_x86_64_platform's constraints (os:linux, cpu:x86_64)
    # as pre_platform modifiers.
    bbm_label = "fbcode//buck2/tests/e2e/configurations/cfg_constructor/bxl:test_platform_modifiers"
    bbm_node = ctx.configured_targets(bbm_label)
    bbm_providers = ctx.analysis(bbm_node).providers()
    info = bbm_providers[BuckconfigBackedModifierInfo]

    # Platform has 2 constraints, applied as pre_platform modifiers
    asserts.equals(2, len(info.pre_platform_modifiers))
    asserts.equals(0, len(info.post_platform_modifiers))
    asserts.equals(0, len(info.pre_cli_modifiers))

    # Run cfg_constructor end-to-end with this target in extra_data.
    # A target modifier is needed to avoid the cfg_constructor's early return
    # when no modifiers are present.
    nosan = "ovr_config//build_mode:sanitizer_type[no-san]"
    refs, params = cfg_constructor_pre_constraint_analysis(
        package_modifiers = None,
        legacy_platform = None,
        target_modifiers = [nosan],
        cli_modifiers = [],
        rule_name = "_dummy",
        aliases = ALIASES,
        extra_data = struct(buckconfig_backed_modifiers = bbm_label),
        configuring_exec_dep = False,
    )

    ref_providers = {}
    for ref in refs:
        if ref == bbm_label:
            ref_providers[ref] = bbm_providers
        else:
            ref_providers[ref] = test_refs.get(ref)

    platform = cfg_constructor_post_constraint_analysis(refs = ref_providers, params = params)

    expected_cfg = test_refs.make_cfg([
        "ovr_config//os/constraints:linux",
        "ovr_config//cpu/constraints:x86_64",
        nosan,
    ])
    asserts.equals(expected_cfg, platform.configuration)
    asserts.equals("cfg:linux-x86_64-no-san", platform.label)

test = bxl_main(
    impl = _impl,
    cli_args = {},
)
